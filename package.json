{
  "private": true,
  "name": "@ORGANIZATION/PROJECT",
  "version": "0.1.0",
  "description": "Starter kit of Nestia",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -C packages/backend dev",
    "format": "pnpm -r --if-present format",
    "lint": "pnpm -r --if-present lint",
    "start": "pnpm -C packages/backend start",
    "test": "pnpm -C packages/backend test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia-start"
  },
  "keywords": [
    "nestia",
    "template",
    "boilerplate"
  ],
  "author": "AUTHOR",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia-start/issues"
  },
  "homepage": "https://github.com/samchon/nestia-start#readme",
  "packageManager": "pnpm@10.10.0",
  "stackblitz": {
    "startCommand": "pnpm install && pnpm test -- --simultaneous 1"
  }
}
