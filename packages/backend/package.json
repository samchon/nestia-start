{
  "private": true,
  "name": "@ORGANIZATION/PROJECT-backend",
  "version": "0.1.0",
  "description": "Starter kit of Nestia",
  "main": "lib/index.js",
  "scripts": {
    "benchmark": "ttsx --project test/tsconfig.json test/benchmark/index.ts",
    "test": "ttsx --project test/tsconfig.json test/index.ts",
    "------------------------BUILDS------------------------": "",
    "build": "pnpm build:sdk && pnpm build:main",
    "build:main": "rimraf lib && ttsc -p tsconfig.json",
    "build:sdk": "rimraf ../api/src/functional && node ../api/scripts/ensure-nestia-exports.cjs && nestia all && node ../api/scripts/ensure-nestia-exports.cjs",
    "build:swagger": "nestia swagger",
    "build:test": "ttsc -p test/tsconfig.json",
    "dev": "ttsc -p test/tsconfig.json --watch",
    "format": "ttsc format -p tsconfig.json",
    "lint": "ttsc -p tsconfig.json --noEmit",
    "prepare": "node build/env.js",
    "------------------------WEBPACK------------------------": "",
    "webpack": "rimraf dist && pnpm build:main && webpack",
    "webpack:start": "cd dist && node server",
    "webpack:test": "pnpm webpack && ttsx --project test/tsconfig.json test/webpack.ts",
    "------------------------DEPLOYS------------------------": "",
    "start": "ttsx src/executable/server.ts",
    "start:prod": "node lib/executable/server",
    "start:dev": "nest start --watch",
    "start:swagger": "ttsx src/executable/swagger.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/nestia-start"
  },
  "keywords": [
    "nestia",
    "template",
    "boilerplate"
  ],
  "author": "AUTHOR",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/nestia-start/issues"
  },
  "homepage": "https://github.com/samchon/nestia-start#readme",
  "devDependencies": {
    "@nestia/benchmark": "catalog:samchon",
    "@ORGANIZATION/PROJECT-config": "workspace:*",
    "@nestia/e2e": "catalog:samchon",
    "@nestjs/cli": "^11.0.16",
    "@ttsc/lint": "catalog:typescript",
    "@ttsc/paths": "catalog:typescript",
    "@types/cli-progress": "^3.11.5",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^8.2.5",
    "@types/node": "^24.0.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "copy-webpack-plugin": "^11.0.0",
    "express": "^4.18.2",
    "inquirer": "^8.2.5",
    "nestia": "catalog:samchon",
    "rimraf": "catalog:utils",
    "swagger-ui-express": "^5.0.0",
    "ttsc": "catalog:typescript",
    "typescript": "catalog:typescript",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "write-file-webpack-plugin": "^4.5.1"
  },
  "dependencies": {
    "@nestia/core": "catalog:samchon",
    "@nestia/fetcher": "catalog:samchon",
    "@nestia/sdk": "catalog:samchon",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@ORGANIZATION/PROJECT-api": "workspace:^",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "dotenv-expand": "^10.0.0",
    "serialize-error": "^4.1.0",
    "source-map-support": "^0.5.21",
    "tgrid": "catalog:samchon",
    "tstl": "catalog:samchon",
    "typia": "catalog:samchon",
    "uuid": "catalog:utils"
  }
}
